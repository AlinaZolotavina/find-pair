{
  "compilerOptions": {
    "target": "ES6",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "jsx": "react-jsx",
    "noEmit": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "noImplicitAny": true,
    "strictNullChecks": true
  },
  "include": ["src"]
}
